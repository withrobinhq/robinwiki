# ═══════════════════════════════════════════════════════════════════════
# Robin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# Copy to .env and fill in values.
# [REQUIRED] = server won't start without it (validated by createConfigVar)
# [OPTIONAL] = has a sensible default
#
# Generate secrets: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════════

# ----- Core (API + workers) ------------------------------------------------

# [REQUIRED] PostgreSQL connection. Must have pgvector extension.
# Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/robinwiki

# [REQUIRED] Redis for BullMQ job queues.
# Railway: ${{Redis.REDIS_URL}}
REDIS_URL=redis://localhost:6379

# [REQUIRED] Better Auth session signing key. 32+ chars.
# Generate: openssl rand -hex 32
# Changing this invalidates all active sessions.
BETTER_AUTH_SECRET=

# [REQUIRED] Master encryption key. Exactly 64 hex chars.
# Generate: openssl rand -hex 32
# Wraps/unwraps the user's Data Encryption Key (DEK).
MASTER_KEY=

# [REQUIRED] Key encryption secret. 32+ chars.
# Generate: openssl rand -hex 32
# Used by generateKeypair() for Ed25519 private key encryption.
KEY_ENCRYPTION_SECRET=

# [REQUIRED] Password recovery secret. 32+ chars.
# Generate: openssl rand -hex 32
# Used ONLY by POST /auth/recover. Keep this separate from
# BETTER_AUTH_SECRET so a session-secret leak does not also enable password
# resets. Update the in-prod value via your secret manager and tell every
# operator the rotated value out-of-band — there is no UI to read it.
RECOVERY_SECRET=

# [REQUIRED in production] HMAC secret for BullMQ job payload signing. 32+ chars.
# Generate: openssl rand -hex 32
# Producer signs every job payload; worker verifies and rejects on mismatch.
# Local dev falls back to a fixed sentinel when missing — see worker boot logs.
JOB_SIGNING_SECRET=

# [REQUIRED] OpenRouter API key for LLM calls and embeddings.
# Get one at: https://openrouter.ai/keys
# Read from env at runtime — NOT stored in the database.
OPENROUTER_API_KEY=

# [REQUIRED] Email for the single admin user.
# Created on first login via JIT provisioning.
INITIAL_USERNAME=you@example.com

# [REQUIRED] Password for the initial user.
# To reset: navigate to /recover and enter RECOVERY_SECRET (NOT BETTER_AUTH_SECRET).
INITIAL_PASSWORD=change-me

# [REQUIRED] Public URL where this server is reachable.
# Used for: MCP endpoint URLs, auth cookie domain, Better Auth baseURL.
# Local: http://localhost:3000
# Production: https://api.yourdomain.com
SERVER_PUBLIC_URL=http://localhost:3000

# [REQUIRED] Wiki frontend origin(s) for CORS + Better Auth trusted origins.
# Comma-separated for multiple origins.
# Local: http://localhost:8080
# Production: https://app.yourdomain.com
# Both: http://localhost:8080,https://app.yourdomain.com
WIKI_ORIGIN=http://localhost:8080

# [OPTIONAL] Server port. Default: 3000. Railway sets this automatically.
PORT=3000

# [OPTIONAL] Node environment. Default: development.
# Set "production" for deploys (enables secure cookies, disables pino-pretty).
NODE_ENV=development

# [OPTIONAL] Pino log level. Default: info.
LOG_LEVEL=info

# ----- Pipeline tuning (all optional) --------------------------------------

# LLM confidence threshold for filing fragments into wikis.
# Range: 0.0-1.0. Default: 0.65. Affects both ingest and regen re-link.
# WIKI_CLASSIFY_THRESHOLD=0.65

# Fragment deduplication similarity threshold. Default: 0.6.
# DEDUP_THRESHOLD=0.6

# Fragment-to-fragment relation threshold. Default: 0.5.
# FRAG_RELATE_THRESHOLD=0.5

# Enable midnight batch regen cron (0 0 * * * UTC). Default: true.
# ENABLE_BATCH_REGEN=true

# ----- Wiki (Next.js frontend) ---------------------------------------------

# [REQUIRED] Robin core API URL for Next.js rewrites.
# Local: http://localhost:3000
# Railway: http://${{core.RAILWAY_PRIVATE_DOMAIN}}:${{core.PORT}}
NEXT_PUBLIC_ROBIN_API=http://localhost:3000
