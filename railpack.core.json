{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": { "node": "20" },
  "steps": {
    "install": {
      "inputs": [{ "step": "packages:mise" }, { "local": true, "include": ["."] }],
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.15.1 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["pnpm --filter @robin/core... build"]
    }
  },
  "deploy": {
    "base": { "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.3.17" },
    "inputs": [
      { "step": "packages:mise", "include": ["/mise/shims", "/mise/installs", "/usr/local/bin/mise", "/etc/mise/config.toml", "/root/.local/state/mise"] },
      { "step": "install", "include": ["node_modules", "packages/shared/node_modules", "packages/agent/node_modules", "packages/queue/node_modules", "packages/caslock/node_modules", "core/node_modules"] },
      { "step": "build", "include": ["."] }
    ],
    "startCommand": "/mise/shims/node core/dist/index.js"
  }
}
