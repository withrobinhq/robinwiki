{
  "name": "@robin/core",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate-with-preserve.ts",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "mcp:inspect": "npx @modelcontextprotocol/inspector",
    "openapi:manifest": "tsx scripts/generate-openapi-manifest.ts",
    "seed-fixture": "tsx scripts/seed-fixture.ts",
    "eval": "evalite run --threshold 50 eval",
    "eval:watch": "evalite watch eval"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/hono": "^6.20.3",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@robin/agent": "workspace:*",
    "@robin/caslock": "workspace:*",
    "@robin/queue": "workspace:*",
    "@robin/shared": "workspace:*",
    "archiver": "^7.0.1",
    "better-auth": "^1.0.0",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "hono": "^4.4.0",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.0.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/yauzl": "^2.10.3",
    "autoevals": "^0.0.132",
    "drizzle-kit": "^0.31.9",
    "evalite": "^0.19.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.1",
    "yauzl": "^3.3.0",
    "zod-to-json-schema": "^3.25.1"
  }
}
