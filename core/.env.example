# ═══════════════════════════════════════════════════════════════════════
# Robin Core — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values.
# All variables marked [REQUIRED] must be set or the server will not start.
# Variables marked [OPTIONAL] have sensible defaults.
#
# Generate secrets:  openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════════

# === Server ===

# [OPTIONAL] Port the server listens on. Default: 3000
PORT=3000

# [OPTIONAL] Node environment. Default: development
# Set to "production" for deployments (enables secure cookies, disables pino-pretty)
NODE_ENV=development

# [OPTIONAL] Pino log level. Default: info
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# [REQUIRED] Public URL where this server is reachable from the internet.
# Used for: MCP endpoint URLs, auth cookie domain, Better Auth baseURL.
# Local dev: http://localhost:3000
# Production: https://api.yourdomain.com (must include https://)
SERVER_PUBLIC_URL=http://localhost:3000

# === Database ===

# [REQUIRED] PostgreSQL connection string.
# The database must have the pgvector extension installed.
# Local dev: postgresql://postgres@127.0.0.1:5432/robinwiki
# Railway: provided by the Postgres plugin
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/robinwiki

# === Redis ===

# [REQUIRED] Redis connection string. Used by BullMQ for job queues.
# Local dev: redis://localhost:6379
# Railway: provided by the Redis plugin
REDIS_URL=redis://localhost:6379

# === Auth ===

# [REQUIRED] Session signing key for Better Auth. Must be 32+ characters.
# Generate: openssl rand -hex 32
# Changing this invalidates all active sessions.
BETTER_AUTH_SECRET=change-me-32-chars-minimum-padding

# === Crypto ===

# [REQUIRED] Master encryption key. Exactly 64 hex characters.
# Generate: openssl rand -hex 32
# Used to wrap/unwrap the user's Data Encryption Key (DEK).
# Losing this key = losing access to encrypted data (keypairs, configs).
MASTER_KEY=

# [REQUIRED] Key encryption secret. 32+ characters.
# Used by generateKeypair() to encrypt the Ed25519 private key via AES-256-GCM.
# Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=

# [REQUIRED] Password recovery secret. 32+ chars.
# Generate: openssl rand -hex 32
# Used ONLY by POST /auth/recover. Keep this separate from
# BETTER_AUTH_SECRET so a session-secret leak does not also enable password
# resets. Update the in-prod value via your secret manager and tell every
# operator the rotated value out-of-band — there is no UI to read it.
RECOVERY_SECRET=

# === Initial User (Single-Tenant) ===

# [REQUIRED] Email address for the single admin user.
# The user is created on first login via JIT provisioning (no boot seed).
INITIAL_USERNAME=you@example.com

# [REQUIRED] Password for the initial user.
# To reset: navigate to /recover in the wiki UI and enter the RECOVERY_SECRET
# (NOT BETTER_AUTH_SECRET).
INITIAL_PASSWORD=change-me

# === AI ===

# [REQUIRED] OpenRouter API key for LLM calls and embeddings.
# Get one at: https://openrouter.ai/keys
# Used by: extraction worker, wiki classifier, wiki regeneration, embedding generation.
# This key is read from env at runtime — it is NOT stored in the database.
OPENROUTER_API_KEY=

# === Frontend ===

# [REQUIRED] Wiki frontend URL(s) for CORS and Better Auth trusted origins.
# Comma-separated for multiple origins (e.g., local + production domain).
# Local dev: http://localhost:8080
# Production: https://app.yourdomain.com
# Both: http://localhost:8080,https://app.yourdomain.com
WIKI_ORIGIN=http://localhost:8080

# === Pipeline Tuning (all optional) ===

# [OPTIONAL] LLM confidence threshold for filing fragments into wikis.
# Range: 0.0-1.0. Default: 0.65
# Lower = more fragments filed (more recall, less precision).
# Higher = fewer fragments filed (less recall, more precision).
# Also affects the ingest pipeline (link worker), not just regen re-link.
# WIKI_CLASSIFY_THRESHOLD=0.65

# [OPTIONAL] Enable the midnight batch regen cron (0 0 * * * UTC).
# Default: true. Set to "false" to disable.
# The cron finds wikis with unfiled fragments, new fragments since last rebuild,
# or stuck in non-RESOLVED state, and enqueues regen jobs.
# ENABLE_BATCH_REGEN=true
